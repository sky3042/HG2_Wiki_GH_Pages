    "1bf3b07c-81ff-8024-8fa8-d904ac9c027e": {
      "value": {
        "id": "1bf3b07c-81ff-8024-8fa8-d904ac9c027e",
        "type": "text",
        "properties": {
          "title": [
            [
              "崩壊エネルギー施設や"
            ],
            [
              "死域",
              [
                [
                  "a",
                  "/1bf3b07c81ff80b28c15f4469df560ae?pvs=25"
                ]
              ]
            ],
            [
              "に出現する崩壊創造物。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1742757533330,
        "last_edited_time": 1768123363559
      }
    },
    "2e53b07c-81ff-80ac-b2f7-dc96b724594f": {
      "value": {
        "id": "2e53b07c-81ff-80ac-b2f7-dc96b724594f",
        "type": "text",
        "properties": {
          "title": [
            [
              "人間に近い生理構造を持ちすぎていて、多くの人工物も融合している。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1768123386247,
        "last_edited_time": 1768123389662
      }
    },
    "1bf3b07c-81ff-80f8-b888-de143b84ef88": {
      "value": {
        "id": "1bf3b07c-81ff-80f8-b888-de143b84ef88",
        "type": "text",
        "properties": {
          "title": [
            [
              "体内から多くの言語が混ざったような低いうなり声が聞こえてくる。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1742758135884,
        "last_edited_time": 1742758219607
      }
    },
    "2e53b07c-81ff-8084-ad44-ea17eee3b6b2": {
      "value": {
        "id": "2e53b07c-81ff-8084-ad44-ea17eee3b6b2",
        "type": "text",
        "properties": {
          "title": [
            [
              "一般的に人を積極的に攻撃することはないが、死域内の帰還者は非常に攻撃的な性質を持っている。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1768123305789,
        "last_edited_time": 1768123399412
      }
    },
    "2e53b07c-81ff-80c6-9bb1-f4b26b403c83": {
      "value": {
        "id": "2e53b07c-81ff-80c6-9bb1-f4b26b403c83",
        "type": "text",
        "properties": {
          "title": [
            [
              "死域を生み出す装置への供給を断ち切れば、ほとんどの死域は自然に閉じ、帰還者も崩壊する。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1768123306442,
        "last_edited_time": 1768123420996
      }
    },
    "1bf3b07c-81ff-802a-87df-c9ac8bce88ec": {
      "value": {
        "id": "1bf3b07c-81ff-802a-87df-c9ac8bce88ec",
        "type": "text",
        "properties": {
          "title": [
            [
              "死域から離れれば離れるほど弱くなる。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1742758124712,
        "last_edited_time": 1768123429189
      }
    },
    "2e53b07c-81ff-80ca-a150-fe8c2374d2a7": {
      "value": {
        "id": "2e53b07c-81ff-80ca-a150-fe8c2374d2a7",
        "type": "text",
        "properties": {
          "title": [
            [
              "帰還者自身は自身を人間、人間を帰還者だと認識している。"
            ]
          ]
        },
        "parent_id": "1bf3b07c-81ff-80f9-a733-ed6a4f3c1b69",
        "parent_table": "block",
        "created_time": 1768123551618,
        "last_edited_time": 1774254623047
      }
    },
