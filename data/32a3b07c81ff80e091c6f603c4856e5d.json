e5gy1i4ux2xb7ddj21dg0sgnl5.jpg"]]},"format":{"block_width":703.9783935546875,"display_source":"attachment:36c34bc2-0e57-466c-ab01-99846689af13:760ca1e5gy1i4ux2xb7ddj21dg0sgnl5.jpg","block_full_width":false,"block_page_width":true,"block_aspect_ratio":0.5752808988764045,"block_preserve_scale":true},"parent_id":"32a3b07c-81ff-80e0-91c6-f603c4856e5d","parent_table":"block","created_time":1774072089428,"last_edited_time":1774072095053}},"32a3b07c-81ff-8015-ae97-d9a833c17d8f":{"value":{"id":"32a3b07c-81ff-8015-ae97-d9a833c17d8f","type":"callout","format":{"block_color":"gray_background","callout_version":2},"content":["32a3b07c-81ff-8097-83e6-c64c9e012a70","32a3b07c-81ff-809f-98e1-e1c7d7c3fdd6"],"parent_id":"32a3b07c-81ff-80e0-91c6-f603c4856e5d","parent_table":"block","created_time":1774072459353,"last_edited_time":1774072462918}},"32a3b07c-81ff-806f-8d64-ddd889ee6b81":{"value":{"id":"32a3b07c-81ff-806f-8d64-ddd889ee6b81","type":"callout","format":{"block_color":"gray_background","callout_version":2},"content":["32a3b07c-81ff-80c3-b882-eebf024d483d","32a3b07c-81ff-8056-9dfd-d0588eadc34e","32a3b07c-81ff-80b5-bd7c-ed94eb933a81"],"parent_id":"32a3b07c-81ff-80e0-91c6-f603c4856e5d","parent_table":"block","created_time":1774072500100,"last_edited_time":1774072504213}},"32a3b07c-81ff-8097-83e6-c64c9e012a70":{"value":{"id":"32a3b07c-81ff-8097-83e6-c64c9e012a70","type":"text","properties":{"title":[["かつては崩壊学園の第二期生であり、温和だが臆病なイメージが人々に深く刻まれている。現在はオグウィンの総督を務めているが、政治的才能に欠けるため、彼女の統治下で都市は全く発展していない。"]]},"parent_id":"32a3b07c-81ff-8015-ae97-d9a833c17d8f","parent_table":"block","created_time":1774072414520,"last_edited_time":1774072462082}},"32a3b07c-81ff-809f-98e1-e1c7d7c3fdd6":{"value":{"id":"32a3b07c-81ff-809f-98e1-e1c7d7c3fdd6","type":"text","properties":{"title":[["その後、彼女はモーリオ・エイトが引き起こした連続殺人事件、および神壁騎士団と崩壊学園の交戦の機会に乗じて、オグウィン内で母親であるサクリフィスに対する反乱を起こし、帰還者の狂潮の中で市民を見捨てて顧みなかった……"]]},"parent_id":"32a3b07c-81ff-8015-ae97-d9a833c17d8f","parent_table":"block","created_time":1774072414521,"last_edited_time":1774072483739}},"32a3b07c-81ff-80c3-b882-eebf024d483d":{"value":{"id":"32a3b07c-81ff-80c3-b882-eebf024d483d","type":"text","properties":{"title":[["しかし、真相はそれだけにとどまらない。"]]},"parent_id":"32a3b07c-81ff-806f-8d64-ddd889ee6b81","parent_table":"block","created_time":1774072414521,"last_edited_time":1774072503268}},"32a3b07c-81ff-8056-9dfd-d0588eadc34e":{"value":{"id":"32a3b07c-81ff-8056-9dfd-d0588eadc34e","type":"text","properties":{"title":[["メミニ・ロアはずっとモーリオ・エイトとある種の見えない繋がりを維持していた。彼女はそれを享受し、さらにそれを利用して「魔樹軍団」の後継者という重責から逃避していた。\n彼女が自らの手でモーリオ・エイトの命を終わらせて初めて、運命に立ち向かう決心をし、母親に対して反旗を翻すことを選んだのだ。"]]},"parent_id":"32a3b07c-81ff-806f-8d64-ddd889ee6b81","parent_table":"block","created_time":1774072414522,"last_edited_time":1774072534639}},"32a3b07c-81ff-80b5-bd7c-ed94eb933a81":{"value":{"id":"32a3b07c-81ff-80b5-bd7c-ed94eb933a81","type":"text","properties":{"title":[["しかし、最後の最後で……同じく「死者の散歩」を掌握する聖痕使いでありながら、彼女は依然として母親の遺体を直視する勇気がなく、サクリフィスの幾重にも張り巡らされた計略を見抜くことができず、最終的に逆襲に遭ってしまった。"]]},"parent_id":"32a3b07c-81ff-806f-8d64-ddd889ee6b81","parent_table":"block","created_time":1774072414522,"last_edited_time":1774072550003}}},"collection":{"32a3b07c-81ff-80d1-bcdf-000b6443ec8b":{"value":{"id":"32a3b07c-81ff-80d1-bcdf-000b6443ec8b","version":10,"name":[["中国情報"]],"schema":{"LyhT":{"name":"Slug","type":"text"},"title":{"name":"名前","type":"title"}},"format":{"ai_suggested_properties":[{"name":"電話番号","type":"phone_number"},{"name":"メールアドレス","type":"email"},{"name":"国","type":"select","options":[{"id":"]J\\{","color":"orange","value":"日本"},{"id":"htyR","color":"blue","value":"中国"},{"id":"\\mlw","color":"default","value":"韓国"},{"id":"@U{O","color":"yellow","value":"アメリカ"}]},{"name":"登録日","type":"date"}]},"parent_id":"32a3b07c-81ff-800c-8202-f3a6249171f7","parent_table":"block","alive":true,"migrated":true,"space_id":"f25e8375-dff8-499a-b7bf-74566e1055df","created_time":1774072132805,"last_edited_time":1774072203538,"created_by_table":"notion_user","created_by_id":"4e3acacc-a0e3-4eec-9056-a8f0