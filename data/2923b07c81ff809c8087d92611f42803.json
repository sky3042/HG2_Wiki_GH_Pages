                [
                  "b"
                ]
              ]
            ],
            [
              "；\n“"
            ],
            [
              "电",
              [
                [
                  "b"
                ]
              ]
            ],
            [
              "”代表生气，或者准备战斗，提振士气的意思，它的战斗方式和"
            ],
            [
              "电有关",
              [
                [
                  "b"
                ]
              ]
            ],
            [
              "；\n“冷”代表悲伤的意思，也太悲伤了，它的钢铁身体"
            ],
            [
              "没有人的体温",
              [
                [
                  "b"
                ]
              ]
            ],
            [
              "；\n“纸”代表恐惧的意思……原因不明。"
            ]
          ]
        },
