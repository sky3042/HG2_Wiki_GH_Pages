    },
    "1c53b07c-81ff-80a2-b8a8-e63e37e58393": {
      "value": {
        "id": "1c53b07c-81ff-80a2-b8a8-e63e37e58393",
        "type": "text",
        "properties": {
          "title": [
            [
              "これはポポと寒鉄の物語をモチーフにしていると思われます。"
            ]
          ]
        },
