    "32d3b07c-81ff-8019-bd8c-ff8deff08749": {
      "value": {
        "id": "32d3b07c-81ff-8019-bd8c-ff8deff08749",
        "type": "text",
        "properties": {
          "title": [
            [
              "Lの肖像を一周読んでみての感想。\n全体的にとても面白かったです。ラニアットの葛藤やメミニとモーリオの関係、明かされる謎と新たな伏線。\n事前に色々と考察していたにも関わらず、予想外の展開の連続でした。"
            ]
          ]
        },
        "format": {
          "copied_from_pointer": {
