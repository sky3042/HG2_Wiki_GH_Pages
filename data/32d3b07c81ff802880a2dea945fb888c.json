      "value": {
        "id": "32d3b07c-81ff-80f3-b764-da61b56c6a15",
        "type": "text",
        "properties": {
          "title": [
            [
              "本格的な考察記事は3週間後くらいに出すと思います。（まだあんまり面白い考察は浮かんでいませんが……）"
            ]
          ]
        },
