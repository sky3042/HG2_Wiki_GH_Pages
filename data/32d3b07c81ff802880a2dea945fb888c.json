        "last_edited_time": 1774334091037
      }
    },
    "32d3b07c-81ff-80fe-a876-ee57147a166c": {
      "value": {
        "id": "32d3b07c-81ff-80fe-a876-ee57147a166c",
        "type": "bulleted_list",
        "properties": {
          "title": [
            [
              "南方貴族はクローンで聖痕を継承する"
            ]
          ]
        },
        "format": {
          "copied_from_pointer": {
            "id": "32a3b07c-81ff-8038-a3b3-f7e88161571b",
